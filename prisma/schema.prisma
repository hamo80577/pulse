generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PICKER
  CHAMP
  AREA_MANAGER
  WORKFORCE_MANAGER
  OPERATIONS_MANAGER
  SENIOR_OPERATIONS_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_SETUP
  ON_HOLD
  SUSPENDED
  RESIGNED
  DELETED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BranchAssignmentRole {
  PICKER
  CHAMP
}

enum AssignmentStatus {
  ACTIVE
  ENDED
}

enum ManagerRelationType {
  CHAMP_TO_PICKER
  AREA_MANAGER_TO_CHAMP
  OPERATIONS_TO_AREA_MANAGER
}

enum ManagerRelationStatus {
  ACTIVE
  ENDED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  ON_HOLD
  RESIGNED
  TERMINATED
}

enum ApprovalRequestType {
  ANNUAL_LEAVE
  ADD_PICKER
  ADD_CHAMP
  TRANSFER_PICKER_SAME_CHAIN
  TRANSFER_PICKER_CROSS_CHAIN
  RESIGNATION
  EMPLOYEE_DATA_UPDATE
}

enum ApprovalRequestStatus {
  DRAFT
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum ApprovalStepStatus {
  WAITING
  ACTIVE
  APPROVED
  REJECTED
  SKIPPED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum NotificationType {
  REQUEST_SUBMITTED
  APPROVAL_REQUIRED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_CANCELLED
  REQUEST_COMPLETED
}

model User {
  id                         String             @id @default(cuid())
  name                       String
  email                      String?            @unique
  phone                      String             @unique
  role                       Role
  status                     UserStatus         @default(PENDING_SETUP)
  passwordHash               String?
  mustChangePassword         Boolean            @default(true)
  lastLoginAt                DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  sessions                   Session[]
  setupTokens                SetupToken[]
  auditLogs                  AuditLog[]         @relation("AuditActor")
  branchAssignments          BranchAssignment[] @relation("BranchAssignmentUser")
  branchAssignmentsCreated   BranchAssignment[] @relation("BranchAssignmentCreator")
  managerRelationsAsEmployee ManagerRelation[]  @relation("ManagerRelationEmployee")
  managerRelationsAsManager  ManagerRelation[]  @relation("ManagerRelationManager")
  employeeProfile            EmployeeProfile?
  approvalRequestsRequested  ApprovalRequest[]  @relation("ApprovalRequester")
  approvalRequestsTargeted   ApprovalRequest[]  @relation("ApprovalTarget")
  approvalStepsAssigned      ApprovalStep[]     @relation("ApprovalStepApprover")
  notifications              Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SetupToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model EmployeeProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  nationalId       String?          @unique
  shopperId        String?          @unique
  ibsId            String?          @unique
  address          String?
  personalPhotoUrl String?
  idCardFrontUrl   String?
  idCardBackUrl    String?
  hireDate         DateTime?
  employmentStatus EmploymentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([employmentStatus])
}

model Chain {
  id                 String             @id @default(cuid())
  name               String
  code               String?
  orderSystemChainId String?            @unique
  status             OrganizationStatus @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  branches           Branch[]

  @@unique([name])
  @@unique([code])
  @@index([status])
}

model Branch {
  id                  String             @id @default(cuid())
  chainId             String
  name                String
  code                String?
  orderSystemBranchId String?            @unique
  address             String?
  status              OrganizationStatus @default(ACTIVE)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  chain               Chain              @relation(fields: [chainId], references: [id], onDelete: Restrict)
  assignments         BranchAssignment[]

  @@unique([chainId, name])
  @@unique([code])
  @@index([chainId])
  @@index([status])
}

model BranchAssignment {
  id           String               @id @default(cuid())
  userId       String
  branchId     String
  roleAtBranch BranchAssignmentRole
  startDate    DateTime
  endDate      DateTime?
  isPrimary    Boolean              @default(true)
  status       AssignmentStatus     @default(ACTIVE)
  createdById  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation("BranchAssignmentUser", fields: [userId], references: [id], onDelete: Restrict)
  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy    User?                @relation("BranchAssignmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([branchId])
  @@index([status])
  @@index([createdById])
}

model ManagerRelation {
  id             String                @id @default(cuid())
  employeeUserId String
  managerUserId  String
  relationType   ManagerRelationType
  startDate      DateTime
  endDate        DateTime?
  status         ManagerRelationStatus @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  employee       User                  @relation("ManagerRelationEmployee", fields: [employeeUserId], references: [id], onDelete: Restrict)
  manager        User                  @relation("ManagerRelationManager", fields: [managerUserId], references: [id], onDelete: Restrict)

  @@index([employeeUserId])
  @@index([managerUserId])
  @@index([status])
}

model ApprovalRequest {
  id               String                @id @default(cuid())
  requestType      ApprovalRequestType
  requesterId      String
  targetUserId     String?
  status           ApprovalRequestStatus @default(PENDING)
  currentStepOrder Int?
  payloadJson      Json
  submittedAt      DateTime?
  finalDecisionAt  DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  requester        User                  @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  targetUser       User?                 @relation("ApprovalTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  steps            ApprovalStep[]

  @@index([requesterId])
  @@index([targetUserId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
}

model ApprovalStep {
  id             String             @id @default(cuid())
  requestId      String
  stepOrder      Int
  approverRole   Role
  approverUserId String?
  status         ApprovalStepStatus @default(WAITING)
  decision       ApprovalDecision?
  comment        String?
  decidedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  request        ApprovalRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver       User?              @relation("ApprovalStepApprover", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@unique([requestId, stepOrder])
  @@index([requestId])
  @@index([status])
  @@index([approverRole])
  @@index([approverUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  linkUrl   String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}
